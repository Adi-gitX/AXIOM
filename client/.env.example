# ── AXIOM client environment ──────────────────────────────────────────────
# Copy to `.env.local` for local dev, or set in your host (Vercel/Netlify) for prod.

# Backend API base (your deployed server). In dev, leave blank to use the Vite proxy.
VITE_API_URL=https://your-backend.example.com

# Peer-interview collaboration WebSocket. Defaults to the API origin in production
# and ws://localhost:8001 in dev; set only if your WS host differs.
# VITE_COLLAB_WS_URL=wss://your-backend.example.com

# Firebase web config — REQUIRED (the app gates rendering on Firebase auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_SENTRY_DSN=

# Local dev only — inject a mock user so the app boots without a real Firebase login.
# Do NOT enable in production.
# VITE_DEV_BYPASS_AUTH=true
