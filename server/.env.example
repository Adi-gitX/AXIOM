# ── AXIOM server environment ──────────────────────────────────────────────
# Copy to `.env` and fill in. In production, set these in your host's env.

# Core
NODE_ENV=production
PORT=8001

# Auth (Firebase) — REQUIRED in production (server verifies Firebase ID tokens)
FIREBASE_API_KEY=your-firebase-web-api-key
# Lock CORS to your deployed frontend origin:
PRODUCTION_FRONTEND_URL=https://your-frontend.example.com
# FRONTEND_URLS=https://staging.example.com,https://preview.example.com

# Database — optional. Omit to use the bundled sql.js file DB (server/data/axiom.db).
# DATABASE_URL=postgres://user:pass@host:5432/axiom

# AI features (Code Lab AI Tutor, hints, polish) — set to enable
EMERGENT_LLM_KEY=your-llm-gateway-key

# Optional server-side judge (Judge0) — see server/JUDGE0.md. Omit to use the
# in-browser harness only.
# JUDGE0_URL=http://localhost:2358
# JUDGE0_API_KEY=
# JUDGE0_RAPIDAPI_HOST=

# Secrets — set strong random values in production
JWT_SECRET=change-me-to-a-long-random-string
ENCRYPTION_SECRET=change-me-to-a-long-random-string

# GitHub OSS integration (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=https://your-frontend.example.com/app/oss
# GITHUB_STATE_SECRET=
# GITHUB_TOKEN_SECRET=

# Media uploads (optional, Cloudinary)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Monitoring (optional)
# SENTRY_DSN=

# Local-dev convenience (NEVER enable in production)
# ALLOW_UNAUTHENTICATED_DEV=true
